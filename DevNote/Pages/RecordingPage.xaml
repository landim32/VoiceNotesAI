<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DevNote.ViewModels"
             x:Class="DevNote.Pages.RecordingPage"
             x:DataType="vm:RecordingViewModel"
             Title="Gravar Nota"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <Grid RowDefinitions="*,Auto,Auto" Padding="24">

        <!-- Visual Feedback Area -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="20">

            <!-- Mic Icon with pulse rings -->
            <Grid WidthRequest="180"
                  HeightRequest="180"
                  HorizontalOptions="Center">

                <!-- Pulse ring 1 (outer) -->
                <BoxView x:Name="PulseRing1"
                         WidthRequest="180"
                         HeightRequest="180"
                         CornerRadius="90"
                         Color="#E53935"
                         Opacity="0"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />

                <!-- Pulse ring 2 (middle) -->
                <BoxView x:Name="PulseRing2"
                         WidthRequest="160"
                         HeightRequest="160"
                         CornerRadius="80"
                         Color="#E53935"
                         Opacity="0"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />

                <!-- Mic circle -->
                <Frame x:Name="MicFrame"
                       WidthRequest="140"
                       HeightRequest="140"
                       CornerRadius="70"
                       Padding="0"
                       BorderColor="Transparent"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       BackgroundColor="{AppThemeBinding Light=#FDE8E0, Dark=#2A1510}">
                    <Label Text="🎙️"
                           FontSize="64"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>
            </Grid>

            <!-- Status -->
            <Label Text="{Binding StatusMessage}"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
        </VerticalStackLayout>

        <!-- Processing Indicator -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsProcessing}"
                             Spacing="8"
                             Margin="0,0,0,16">
            <ActivityIndicator IsRunning="{Binding IsProcessing}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
            <Label Text="Processando..."
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}" />
        </VerticalStackLayout>

        <!-- Stop Button (only visible while recording) -->
        <Button Grid.Row="2"
                Text="⏹  Parar Gravação"
                Command="{Binding StopRecordingCommand}"
                IsVisible="{Binding IsRecording}"
                FontSize="20"
                FontAttributes="Bold"
                HeightRequest="60"
                CornerRadius="30"
                Margin="0,0,0,16"
                BackgroundColor="#E53935"
                TextColor="{StaticResource White}" />
    </Grid>

</ContentPage>
