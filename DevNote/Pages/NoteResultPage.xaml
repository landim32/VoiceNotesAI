<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DevNote.ViewModels"
             x:Class="DevNote.Pages.NoteResultPage"
             x:DataType="vm:NoteResultViewModel"
             Title="Resultado"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <!-- Header -->
            <Label Text="Nota Interpretada pela IA"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            <Label Text="Revise e edite antes de salvar"
                   FontSize="15"
                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}" />

            <!-- Title -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Título"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                <Entry Text="{Binding Title}"
                       Placeholder="Título da nota"
                       FontSize="18"
                       BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       PlaceholderColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <!-- Category -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Categoria"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                <Picker Title="Selecione a categoria"
                        ItemsSource="{Binding AvailableCategories}"
                        SelectedItem="{Binding Category}"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}" />
            </VerticalStackLayout>

            <!-- Description -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Descrição"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                <Editor Text="{Binding Description}"
                        Placeholder="Descrição da nota"
                        FontSize="16"
                        HeightRequest="150"
                        AutoSize="TextChanges"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                        TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                        PlaceholderColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <!-- Transcribed Text (read-only) -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Texto Transcrito"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                <Frame Padding="12"
                       CornerRadius="8"
                       BorderColor="Transparent"
                       BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                    <Label Text="{Binding TranscribedText}"
                           FontSize="15"
                           FontAttributes="Italic"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                </Frame>
            </VerticalStackLayout>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,0">
                <Button Grid.Column="0"
                        Text="Cancelar"
                        Command="{Binding CancelCommand}"
                        FontSize="17"
                        HeightRequest="50"
                        CornerRadius="25"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />

                <Button Grid.Column="1"
                        Text="Salvar"
                        Command="{Binding SaveNoteCommand}"
                        IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                        FontSize="17"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="25"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
            </Grid>

            <!-- Saving Indicator -->
            <ActivityIndicator IsRunning="{Binding IsSaving}"
                               IsVisible="{Binding IsSaving}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
