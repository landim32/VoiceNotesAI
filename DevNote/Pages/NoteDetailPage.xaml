<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DevNote.ViewModels"
             xmlns:dto="clr-namespace:DevNote.DTOs;assembly=DevNote.DTO"
             x:Class="DevNote.Pages.NoteDetailPage"
             x:DataType="vm:NoteDetailViewModel"
             Title="{Binding PageTitle}"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <Grid>
        <!-- Main Content -->
        <ScrollView Padding="20">
            <VerticalStackLayout Spacing="16">

                <!-- Created At -->
                <Label Text="{Binding CreatedAt, StringFormat='Criada em {0:dd/MM/yyyy HH:mm}'}"
                       FontSize="12"
                       IsVisible="{Binding IsNewNote, Converter={StaticResource InvertedBoolConverter}}"
                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />

                <!-- Notas (Description - primary field) -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Notas"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    <Editor Text="{Binding Description}"
                            Placeholder="Conteúdo da nota"
                            FontSize="14"
                            HeightRequest="200"
                            AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                            TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                            PlaceholderColor="{StaticResource Gray400}" />
                </VerticalStackLayout>

                <!-- Category -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Categoria"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    <Picker Title="Selecione a categoria"
                            ItemsSource="{Binding AvailableCategories}"
                            SelectedItem="{Binding Category}"
                            TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}" />
                </VerticalStackLayout>

                <!-- Title (optional) -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Título (opcional)"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                    <Entry Text="{Binding Title}"
                           Placeholder="Preenchido automaticamente se vazio"
                           FontSize="16"
                           BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                           TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                           PlaceholderColor="{StaticResource Gray400}" />
                </VerticalStackLayout>

                <!-- Comments Section -->
                <VerticalStackLayout Spacing="8"
                                     IsVisible="{Binding IsNewNote, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="Comentários"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />

                    <CollectionView ItemsSource="{Binding Comments}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:CommentInfo">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Excluir"
                                                       BackgroundColor="#E53935"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NoteDetailViewModel}}, Path=DeleteCommentCommand}"
                                                       CommandParameter="{Binding}" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <Frame Margin="0,4"
                                           Padding="12"
                                           CornerRadius="10"
                                           BorderColor="Transparent"
                                           BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="{Binding Content}"
                                                   FontSize="13"
                                                   TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                                            <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                                   FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                                        </VerticalStackLayout>
                                    </Frame>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <CollectionView.EmptyView>
                            <Label Text="Nenhum comentário ainda"
                                   FontSize="13"
                                   FontAttributes="Italic"
                                   HorizontalOptions="Center"
                                   Margin="0,8"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                        </CollectionView.EmptyView>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Action Buttons (edit mode) -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,0"
                      IsVisible="{Binding IsNewNote, Converter={StaticResource InvertedBoolConverter}}">
                    <Button Grid.Column="0"
                            Text="Excluir"
                            Command="{Binding DeleteCommand}"
                            FontSize="15"
                            HeightRequest="50"
                            CornerRadius="25"
                            BackgroundColor="#E53935"
                            TextColor="{StaticResource White}" />

                    <Button Grid.Column="1"
                            Text="Salvar"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                            FontSize="15"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="25"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
                </Grid>

                <!-- Save Button (creation mode - full width) -->
                <Button Text="Salvar"
                        Command="{Binding SaveCommand}"
                        IsVisible="{Binding IsNewNote}"
                        IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="25"
                        Margin="0,12,0,0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />

                <!-- Saving/Consolidating Indicator -->
                <ActivityIndicator IsRunning="{Binding IsSaving}"
                                   IsVisible="{Binding IsSaving}"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                <!-- Bottom padding for FAB -->
                <BoxView HeightRequest="80"
                         IsVisible="{Binding IsNewNote, Converter={StaticResource InvertedBoolConverter}}"
                         Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Recording Overlay -->
        <Grid IsVisible="{Binding IsRecordingComment}"
              BackgroundColor="#CC000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="20">
                <ActivityIndicator IsRunning="True"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   WidthRequest="48"
                                   HeightRequest="48" />
                <Label Text="{Binding RecordingStatus}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />
                <Button Text="Parar Gravação"
                        Command="{Binding StopVoiceCommentCommand}"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="25"
                        BackgroundColor="#E53935"
                        TextColor="White"
                        HorizontalOptions="Center"
                        WidthRequest="200" />
            </VerticalStackLayout>
        </Grid>

        <!-- Transcribing Overlay -->
        <Grid IsVisible="{Binding IsTranscribing}"
              BackgroundColor="#CC000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="20">
                <ActivityIndicator IsRunning="True"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   WidthRequest="48"
                                   HeightRequest="48" />
                <Label Text="Transcrevendo..."
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Improving with AI Overlay -->
        <Grid IsVisible="{Binding IsImproving}"
              BackgroundColor="#CC000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="20">
                <ActivityIndicator IsRunning="True"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   WidthRequest="48"
                                   HeightRequest="48" />
                <Label Text="Melhorando com IA..."
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Consolidating Overlay -->
        <Grid IsVisible="{Binding IsConsolidating}"
              BackgroundColor="#CC000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="20">
                <ActivityIndicator IsRunning="True"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   WidthRequest="48"
                                   HeightRequest="48" />
                <Label Text="Consolidando com IA..."
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- FAB Menu Backdrop -->
        <BoxView Color="#000000"
                 Opacity="0.4"
                 IsVisible="{Binding IsFabMenuOpen}"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleFabMenuCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- FAB Menu Options -->
        <VerticalStackLayout IsVisible="{Binding IsFabMenuOpen}"
                             HorizontalOptions="End"
                             VerticalOptions="End"
                             Margin="0,0,8,96"
                             Spacing="12">

            <!-- Improve with AI Option -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                <Label Text="Melhorar com IA"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"
                       Padding="10,6"
                       BackgroundColor="#CC333333">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ImproveWithAICommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Border StrokeThickness="0"
                        WidthRequest="48"
                        HeightRequest="48"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Shadow="{Shadow Brush=Black, Offset='1,2', Radius=4, Opacity=0.3}"
                        StrokeShape="RoundRectangle 24">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ImproveWithAICommand}" />
                    </Border.GestureRecognizers>
                    <Path Data="M19 9l1.25-2.75L23 5l-2.75-1.25L19 1l-1.25 2.75L15 5l2.75 1.25L19 9zM11.5 9.5L9 4 6.5 9.5 1 12l5.5 2.5L9 20l2.5-5.5L17 12l-5.5-2.5z"
                          Fill="White"
                          Aspect="Uniform"
                          WidthRequest="22"
                          HeightRequest="22"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
            </HorizontalStackLayout>

            <!-- Consolidate with AI Option -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                <Label Text="Consolidar com IA"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"
                       Padding="10,6"
                       BackgroundColor="#CC333333">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ConsolidateWithAICommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Border StrokeThickness="0"
                        WidthRequest="48"
                        HeightRequest="48"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Shadow="{Shadow Brush=Black, Offset='1,2', Radius=4, Opacity=0.3}"
                        StrokeShape="RoundRectangle 24">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ConsolidateWithAICommand}" />
                    </Border.GestureRecognizers>
                    <Path Data="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"
                          Fill="White"
                          Aspect="Uniform"
                          WidthRequest="22"
                          HeightRequest="22"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
            </HorizontalStackLayout>

            <!-- Text Comment Option -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                <Label Text="Comentário em Texto"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"
                       Padding="10,6"
                       BackgroundColor="#CC333333">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AddTextCommentCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Border StrokeThickness="0"
                        WidthRequest="48"
                        HeightRequest="48"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Shadow="{Shadow Brush=Black, Offset='1,2', Radius=4, Opacity=0.3}"
                        StrokeShape="RoundRectangle 24">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AddTextCommentCommand}" />
                    </Border.GestureRecognizers>
                    <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                          Fill="White"
                          Aspect="Uniform"
                          WidthRequest="22"
                          HeightRequest="22"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
            </HorizontalStackLayout>

            <!-- Voice Comment Option -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                <Label Text="Comentário em Voz"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"
                       Padding="10,6"
                       BackgroundColor="#CC333333">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AddVoiceCommentCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Border StrokeThickness="0"
                        WidthRequest="48"
                        HeightRequest="48"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Shadow="{Shadow Brush=Black, Offset='1,2', Radius=4, Opacity=0.3}"
                        StrokeShape="RoundRectangle 24">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AddVoiceCommentCommand}" />
                    </Border.GestureRecognizers>
                    <Path Data="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"
                          Fill="White"
                          Aspect="Uniform"
                          WidthRequest="22"
                          HeightRequest="22"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- FAB Main Button (visible only in edit mode) -->
        <Border StrokeThickness="0"
                WidthRequest="64"
                HeightRequest="64"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,4,16"
                IsVisible="{Binding IsNewNote, Converter={StaticResource InvertedBoolConverter}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                Shadow="{Shadow Brush=Black, Offset='2,4', Radius=8, Opacity=0.3}"
                StrokeShape="RoundRectangle 32">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleFabMenuCommand}" />
            </Border.GestureRecognizers>
            <Label Text="{Binding IsFabMenuOpen, Converter={StaticResource FabIconConverter}}"
                   FontSize="28"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>
    </Grid>

</ContentPage>
