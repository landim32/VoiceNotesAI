<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DevNotes.ViewModels"
             xmlns:dto="clr-namespace:DevNotes.DTOs;assembly=DevNotes.DTO"
             x:Class="DevNotes.Pages.NoteListPage"
             x:DataType="vm:NoteListViewModel"
             Title="Notas"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <Grid Padding="16">

        <Grid RowDefinitions="Auto,*">
            <!-- Category Filter -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Grid.Row="0">
                <HorizontalStackLayout Spacing="8" Padding="0,0,0,12"
                                       BindableLayout.ItemsSource="{Binding FilterCategories}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Text="{Binding ., Converter={StaticResource CategoryFilterTextConverter}}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NoteListViewModel}}, Path=FilterByCategoryCommand}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource ChipButton}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Loading Indicator -->
            <ActivityIndicator Grid.Row="1"
                               IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />

            <!-- Empty State -->
            <VerticalStackLayout Grid.Row="1"
                                 IsVisible="{Binding IsEmpty}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                <Label Text="🎙️"
                       FontSize="48"
                       HorizontalOptions="Center" />
                <Label Text="Nenhuma nota ainda"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                <Label Text="Grave sua primeira nota de voz!"
                       FontSize="14"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}" />
            </VerticalStackLayout>

            <!-- Notes List -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Notes}"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:NoteInfo">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Excluir"
                                               BackgroundColor="#E53935"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NoteListViewModel}}, Path=DeleteNoteCommand}"
                                               CommandParameter="{Binding}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame Margin="0,4"
                                   Padding="16"
                                   CornerRadius="12"
                                   BorderColor="Transparent"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NoteListViewModel}}, Path=GoToDetailCommand}"
                                        CommandParameter="{Binding}" />
                                </Frame.GestureRecognizers>

                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8">
                                    <Label Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                                           Grid.Row="0" Grid.Column="0" />

                                    <Label Text="{Binding Category}"
                                           FontSize="11"
                                           Padding="8,2"
                                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                           BackgroundColor="{AppThemeBinding Light=#FDE8E0, Dark=#2A1510}"
                                           Grid.Row="0" Grid.Column="1"
                                           VerticalOptions="Center" />

                                    <Label Text="{Binding Description}"
                                           FontSize="13"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                           Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Margin="0,4,0,0" />

                                    <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                           FontSize="11"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                           Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                           Margin="0,4,0,0" />
                                </Grid>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- FAB Menu Backdrop -->
        <BoxView Color="#000000"
                 Opacity="0.4"
                 IsVisible="{Binding IsFabMenuOpen}"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleFabMenuCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- FAB Menu Options -->
        <VerticalStackLayout IsVisible="{Binding IsFabMenuOpen}"
                             HorizontalOptions="End"
                             VerticalOptions="End"
                             Margin="0,0,8,96"
                             Spacing="12">

            <!-- Text Note Option -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                <Label Text="Nota de Texto"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"
                       Padding="10,6"
                       BackgroundColor="#CC333333">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToNewTextNoteCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Border StrokeThickness="0"
                        WidthRequest="48"
                        HeightRequest="48"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Shadow="{Shadow Brush=Black, Offset='1,2', Radius=4, Opacity=0.3}"
                        StrokeShape="RoundRectangle 24">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToNewTextNoteCommand}" />
                    </Border.GestureRecognizers>
                    <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                          Fill="White"
                          Aspect="Uniform"
                          WidthRequest="22"
                          HeightRequest="22"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
            </HorizontalStackLayout>

            <!-- Voice Note Option -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="End">
                <Label Text="Nota de Voz"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"
                       Padding="10,6"
                       BackgroundColor="#CC333333">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRecordingCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Border StrokeThickness="0"
                        WidthRequest="48"
                        HeightRequest="48"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        Shadow="{Shadow Brush=Black, Offset='1,2', Radius=4, Opacity=0.3}"
                        StrokeShape="RoundRectangle 24">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRecordingCommand}" />
                    </Border.GestureRecognizers>
                    <Path Data="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"
                          Fill="White"
                          Aspect="Uniform"
                          WidthRequest="22"
                          HeightRequest="22"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- FAB Main Button -->
        <Border StrokeThickness="0"
                WidthRequest="64"
                HeightRequest="64"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,4,16"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                Shadow="{Shadow Brush=Black, Offset='2,4', Radius=8, Opacity=0.3}"
                StrokeShape="RoundRectangle 32">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleFabMenuCommand}" />
            </Border.GestureRecognizers>
            <Label Text="{Binding IsFabMenuOpen, Converter={StaticResource FabIconConverter}}"
                   FontSize="28"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>
    </Grid>

</ContentPage>
