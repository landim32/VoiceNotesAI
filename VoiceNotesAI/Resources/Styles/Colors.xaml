<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand Colors -->
    <Color x:Key="Primary">#F07040</Color>
    <Color x:Key="PrimaryDark">#F07040</Color>
    <Color x:Key="PrimaryLight">#F8A080</Color>
    <Color x:Key="Secondary">#E0E0E0</Color>
    <Color x:Key="SecondaryDark">#B0B0B0</Color>
    <Color x:Key="Accent">#101020</Color>
    <Color x:Key="AccentOrange">#F07000</Color>
    <Color x:Key="AccentTeal">#80C0D0</Color>
    <Color x:Key="Tertiary">#80C0D0</Color>
    <Color x:Key="TertiaryDark">#80C0D0</Color>

    <!-- Neutrals -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <Color x:Key="Gray100">#F5F5F5</Color>
    <Color x:Key="Gray200">#E0E0E0</Color>
    <Color x:Key="Gray300">#BDBDBD</Color>
    <Color x:Key="Gray400">#9E9E9E</Color>
    <Color x:Key="Gray500">#757575</Color>
    <Color x:Key="Gray600">#424242</Color>
    <Color x:Key="Gray900">#1A1A2E</Color>
    <Color x:Key="Gray950">#101020</Color>

    <!-- Semantic -->
    <Color x:Key="Danger">#E53935</Color>

</ResourceDictionary>
