<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VoiceNotesAI.ViewModels"
             x:Class="VoiceNotesAI.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Configurações"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <!-- Header -->
            <Label Text="Configurações da API"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            <Label Text="Configure as credenciais e modelos da OpenAI"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}" />

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            <!-- API Key -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Chave da API (OpenAI)"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                <Entry Text="{Binding ApiKey}"
                       Placeholder="sk-..."
                       IsPassword="True"
                       FontSize="14"
                       BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       PlaceholderColor="{StaticResource Gray400}" />
            </VerticalStackLayout>

            <!-- GPT Model -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Modelo GPT"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                <Entry Text="{Binding GptModel}"
                       Placeholder="gpt-4o"
                       FontSize="14"
                       BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       PlaceholderColor="{StaticResource Gray400}" />
                <Label Text="Ex: gpt-4o, gpt-4o-mini, gpt-3.5-turbo"
                       FontSize="11"
                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
            </VerticalStackLayout>

            <!-- Whisper Model -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Modelo Whisper"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                <Entry Text="{Binding WhisperModel}"
                       Placeholder="whisper-1"
                       FontSize="14"
                       BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                       PlaceholderColor="{StaticResource Gray400}" />
                <Label Text="Ex: whisper-1"
                       FontSize="11"
                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
            </VerticalStackLayout>

            <!-- Save Button -->
            <Button Text="Salvar Configurações"
                    Command="{Binding SaveSettingsCommand}"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="56"
                    CornerRadius="28"
                    Margin="0,12,0,0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />

            <!-- Saving Indicator -->
            <ActivityIndicator IsRunning="{Binding IsSaving}"
                               IsVisible="{Binding IsSaving}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
