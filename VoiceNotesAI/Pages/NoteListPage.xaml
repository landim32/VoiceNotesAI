<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VoiceNotesAI.ViewModels"
             x:Class="VoiceNotesAI.Pages.NoteListPage"
             x:DataType="vm:NoteListViewModel"
             Title="Minhas Notas"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <Shell.TitleColor>
        <AppThemeBinding Light="{StaticResource Primary}" Dark="{StaticResource PrimaryDark}" />
    </Shell.TitleColor>

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">

        <!-- Category Filter -->
        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Grid.Row="0">
            <HorizontalStackLayout Spacing="8" Padding="0,0,0,12">
                <Button Text="Todas"
                        Command="{Binding FilterByCategoryCommand}"
                        CommandParameter=""
                        Style="{StaticResource ChipButton}" />
                <Button Text="Tarefas"
                        Command="{Binding FilterByCategoryCommand}"
                        CommandParameter="Tarefas"
                        Style="{StaticResource ChipButton}" />
                <Button Text="Ideias"
                        Command="{Binding FilterByCategoryCommand}"
                        CommandParameter="Ideias"
                        Style="{StaticResource ChipButton}" />
                <Button Text="Lembretes"
                        Command="{Binding FilterByCategoryCommand}"
                        CommandParameter="Lembretes"
                        Style="{StaticResource ChipButton}" />
                <Button Text="Trabalho"
                        Command="{Binding FilterByCategoryCommand}"
                        CommandParameter="Trabalho"
                        Style="{StaticResource ChipButton}" />
                <Button Text="Pessoal"
                        Command="{Binding FilterByCategoryCommand}"
                        CommandParameter="Pessoal"
                        Style="{StaticResource ChipButton}" />
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12">
            <Label Text="🎙️"
                   FontSize="48"
                   HorizontalOptions="Center" />
            <Label Text="Nenhuma nota ainda"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
            <Label Text="Grave sua primeira nota de voz!"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}" />
        </VerticalStackLayout>

        <!-- Notes List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Notes}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:Object">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Excluir"
                                           BackgroundColor="#E53935"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NoteListViewModel}}, Path=DeleteNoteCommand}"
                                           CommandParameter="{Binding}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Margin="0,4"
                               Padding="16"
                               CornerRadius="12"
                               BorderColor="Transparent"
                               BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NoteListViewModel}}, Path=GoToDetailCommand}"
                                    CommandParameter="{Binding}" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8">
                                <Label Text="{Binding Title}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                                       Grid.Row="0" Grid.Column="0" />

                                <Label Text="{Binding Category}"
                                       FontSize="11"
                                       Padding="8,2"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       BackgroundColor="{AppThemeBinding Light=#EDE7F6, Dark=#2D2040}"
                                       Grid.Row="0" Grid.Column="1"
                                       VerticalOptions="Center" />

                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                       Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Margin="0,4,0,0" />

                                <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                       Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                       Margin="0,4,0,0" />
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- FAB Record Button -->
        <Button Grid.Row="2"
                Text="🎙️  Gravar Nota"
                Command="{Binding GoToRecordingCommand}"
                FontSize="16"
                FontAttributes="Bold"
                HeightRequest="56"
                CornerRadius="28"
                Margin="0,12,0,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
    </Grid>

</ContentPage>
