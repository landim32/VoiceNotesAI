<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VoiceNotesAI.ViewModels"
             x:Class="VoiceNotesAI.Pages.RecordingPage"
             x:DataType="vm:RecordingViewModel"
             Title="Gravar Nota"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">

    <Grid RowDefinitions="*,Auto,Auto,Auto" Padding="24">

        <!-- Visual Feedback Area -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="20">

            <!-- Mic Icon -->
            <Frame WidthRequest="140"
                   HeightRequest="140"
                   CornerRadius="70"
                   Padding="0"
                   BorderColor="Transparent"
                   HorizontalOptions="Center"
                   BackgroundColor="{AppThemeBinding Light=#EDE7F6, Dark=#2D2040}">
                <Label Text="🎙️"
                       FontSize="60"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Frame>

            <!-- Status -->
            <Label Text="{Binding StatusMessage}"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}" />
        </VerticalStackLayout>

        <!-- Processing Indicator -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsProcessing}"
                             Spacing="8"
                             Margin="0,0,0,16">
            <ActivityIndicator IsRunning="{Binding IsProcessing}"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
            <Label Text="Processando..."
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}" />
        </VerticalStackLayout>

        <!-- Record/Stop Button -->
        <Button Grid.Row="2"
                Text="{Binding IsRecording, Converter={StaticResource RecordButtonTextConverter}}"
                Command="{Binding ToggleRecordingCommand}"
                IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertedBoolConverter}}"
                FontSize="18"
                FontAttributes="Bold"
                HeightRequest="60"
                CornerRadius="30"
                Margin="0,0,0,12"
                BackgroundColor="{Binding IsRecording, Converter={StaticResource RecordButtonColorConverter}}"
                TextColor="{StaticResource White}" />

        <!-- Process Button -->
        <Button Grid.Row="3"
                Text="Processar Áudio"
                Command="{Binding ProcessAudioCommand}"
                IsVisible="{Binding IsRecording, Converter={StaticResource InvertedBoolConverter}}"
                IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertedBoolConverter}}"
                FontSize="16"
                HeightRequest="50"
                CornerRadius="25"
                Margin="0,0,0,16"
                BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDark}}"
                TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}" />
    </Grid>

</ContentPage>
